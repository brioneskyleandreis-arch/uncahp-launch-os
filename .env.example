# Supabase Configuration
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-public-anon-key

# Meta Ads API Keys (Server Only)
# Note: For Vercel Serverless deployments, add this via the Vercel Dashboard env vars.
# Since the backend also checks VITE_META_ACCESS_TOKEN for backward compatibility locally,
# you can define it here.
VITE_META_ACCESS_TOKEN=your-meta-access-token
VITE_META_AD_ACCOUNT_ID=your-meta-ad-account-id
